        "entity.name.tag.id",
        "support.class.component.svelte",
        "entity.name.tag.component.svelte"
      ],
      "settings": {
        "foreground": "#4afe83"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.svelte",
        "entity.other.attribute-name.event.svelte",
        "entity.other.attribute-name.bind.svelte",
        "entity.other.attribute-name.transition.svelte",
        "entity.other.attribute-name.animation.svelte",
        "entity.other.attribute-name.action.svelte",
        "entity.other.attribute-name.directive.svelte"
